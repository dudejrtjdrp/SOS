# ── Supabase ─────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI: Google Gemini (FREE tier — no credit card) ───────
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Embedding model for RAG (1536-dim output → matches halfvec(1536))
EMBEDDING_MODEL=gemini-embedding-001

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── File storage: Cloudflare R2 (S3-compatible) ──────────
# 공고문 files/images. Create an R2 bucket + an API token (Object
# Read & Write) in the Cloudflare dashboard, then fill these in.
# Until set, the 공고문 link feature still works; only file/image
# upload is disabled.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: a public bucket / custom domain base URL. If set, files are
# served from here directly instead of via short-lived presigned URLs.
# R2_PUBLIC_BASE_URL=https://files.example.com

# ── Feature flags ────────────────────────────────────────
# AI in-app generation. Set to "false" to hide all AI buttons
# (module run, document generate, AI chat, AI review) and use the
# copy-prompt / paste-result manual paths with an external LLM.
NEXT_PUBLIC_AI_ENABLED=true
